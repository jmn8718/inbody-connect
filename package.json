{
  "name": "inbody-connect",
  "version": "0.1.0",
  "description": "Interface to connect with InBody API",
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs"
    }
  },
  "scripts": {
    "build": "find ./dist -type d -empty -delete; tsup",
    "example": "tsx example/index.ts",
    "lint:check": "biome lint src",
    "format:check": "biome format src",
    "format:fix": "biome format --write src",
    "prepare": "npm run build"
  },
  "keywords": [
    "inbody",
    "typescript",
    "health"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/jmn8718/inbody-connect#readme",
  "bugs": {
    "url": "https://github.com/jmn8718/inbody-connect/issues"
  },
  "files": [
    "dist/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmn8718/inbody-connect.git"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "22.10.0",
    "tsup": "8.4.0",
    "tsx": "4.19.3",
    "typescript": "5.7.2"
  },
  "dependencies": {
    "ky": "1.7.2"
  }
}
